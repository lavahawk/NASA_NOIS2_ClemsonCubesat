# Copy this file to .env and replace the placeholder values before running docker compose.

FIRMS_MAP_KEY=replace_with_your_firms_map_key

POSTGRES_DB=firedb
POSTGRES_USER=fireuser
POSTGRES_PASSWORD=firepass
POSTGRES_PORT=5432

API_PORT=8000
API_PAGE_SIZE=1000
API_MAX_TIME_RANGE_DAYS=10
API_ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://127.0.0.1:3000"]

WORKER_POLL_INTERVAL_SECONDS=300
